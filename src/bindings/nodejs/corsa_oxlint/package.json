{
  "name": "corsa-oxlint",
  "version": "0.1.0",
  "description": "Oxlint-first TypeScript helpers powered by corsa-bind and typescript-go",
  "homepage": "https://github.com/ubugeeei/corsa-bind/tree/main/src/bindings/nodejs/corsa_oxlint",
  "bugs": {
    "url": "https://github.com/ubugeeei/corsa-bind/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/corsa-bind.git",
    "directory": "src/bindings/nodejs/corsa_oxlint"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ast-utils": {
      "types": "./dist/ast_utils.d.ts",
      "import": "./dist/ast_utils.js"
    },
    "./oxlint-utils": {
      "types": "./dist/oxlint_utils.d.ts",
      "import": "./dist/oxlint_utils.js"
    },
    "./json-schema": {
      "types": "./dist/json_schema.d.ts",
      "import": "./dist/json_schema.js"
    },
    "./rule-tester": {
      "types": "./dist/rule_tester.d.ts",
      "import": "./dist/rule_tester.js"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js"
    },
    "./ts-oxlint": {
      "types": "./dist/ts_oxlint.d.ts",
      "import": "./dist/ts_oxlint.js"
    },
    "./ts-estree": {
      "types": "./dist/ts_estree.d.ts",
      "import": "./dist/ts_estree.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@corsa-bind/node": "workspace:*",
    "@oxlint/plugins": "1.57.0",
    "oxlint": "1.57.0"
  },
  "engines": {
    "node": ">=22"
  }
}
